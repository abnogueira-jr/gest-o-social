{
  "name": "AgenteCampo",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome completo do agente de campo"
    },
    "cpf": {
      "type": "string",
      "description": "CPF do agente (formato: 000.000.000-00)"
    },
    "municipio_id": {
      "type": "string",
      "description": "ID do munic\u00edpio atendido (refer\u00eancia \u00e0 entidade Municipio)"
    },
    "municipio_nome": {
      "type": "string",
      "description": "Nome do munic\u00edpio atendido"
    },
    "regiao_cg_id": {
      "type": "string",
      "description": "ID da regi\u00e3o de Campo Grande atendida (refer\u00eancia \u00e0 entidade RegiaoCG)"
    },
    "regiao_cg_nome": {
      "type": "string",
      "description": "Nome da regi\u00e3o de Campo Grande atendida"
    },
    "ativo": {
      "type": "boolean",
      "default": true,
      "description": "Indica se o agente est\u00e1 ativo no sistema"
    }
  },
  "required": [
    "nome",
    "cpf"
  ]
}